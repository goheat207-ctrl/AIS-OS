    "template_ais_article_clip":  {
                                      "schemaVersion":  "0.1.0",
                                      "id":  "ais_article_clip",
                                      "name":  "AIS-OS - Article / Web Page",
                                      "behavior":  "create",
                                      "vault":  "Agentic_OS",
                                      "noteNameFormat":  "{{date|date:\"YYYY-MM-DD\"}} - {{title|safe_name|trim}}",
                                      "path":  "raw/articles",
                                      "context":  "{{content|slice:0,12000|trim}}",
                                      "properties":  [
                                                         {
                                                             "name":  "title",
                                                             "value":  "{{title}}",
                                                             "type":  "text"
                                                         },
                                                         {
                                                             "name":  "type",
                                                             "value":  "source",
                                                             "type":  "text"
                                                         },
                                                         {
                                                             "name":  "tags",
                                                             "value":  "clippings, raw_article, second_brain, needs_ingest",
                                                             "type":  "multitext"
                                                         },
                                                         {
                                                             "name":  "source_count",
                                                             "value":  "1",
                                                             "type":  "number"
                                                         },
                                                         {
                                                             "name":  "created",
                                                             "value":  "{{date|date:\"YYYY-MM-DD\"}}",
                                                             "type":  "date"
                                                         },
                                                         {
                                                             "name":  "updated",
                                                             "value":  "{{date|date:\"YYYY-MM-DD\"}}",
                                                             "type":  "date"
                                                         },
                                                         {
                                                             "name":  "source",
                                                             "value":  "{{url}}",
                                                             "type":  "text"
                                                         },
                                                         {
                                                             "name":  "site",
                                                             "value":  "{{site}}",
                                                             "type":  "text"
                                                         },
                                                         {
                                                             "name":  "author",
                                                             "value":  "{{author}}",
                                                             "type":  "text"
                                                         },
                                                         {
                                                             "name":  "published",
                                                             "value":  "{{published|date:\"YYYY-MM-DD\"}}",
                                                             "type":  "date"
                                                         },
                                                         {
                                                             "name":  "status",
                                                             "value":  "needs_ingest",
                                                             "type":  "text"
                                                         }
                                                     ],
                                      "triggers":  [
                                                       "schema:@Article",
                                                       "schema:@NewsArticle",
                                                       "schema:@BlogPosting"
                                                   ],
                                      "noteContentFormat":  "# {{title}}\n\n## Why I saved this\n\n- \n\n## Key idea\n\n- \n\n## Source\n\n- URL: {{url}}\n- Site: {{site}}\n- Author: {{author}}\n- Clipped: {{date|date:\"YYYY-MM-DD\"}}\n\n## Content\n\n{{content}}\n\n## Next ingest action\n\nAsk Codex: \"Ingest this clip into the second brain if it is useful: [[{{date|date:\"YYYY-MM-DD\"}} - {{title|safe_name|trim}}]]\"\n"
                                  },
